# Momentus — local secrets template.
#
# 1. Copy this file to `secrets.toml` in the same directory:
#       cp secrets.toml.example secrets.toml
# 2. Paste your real key after the equals sign in the copy.
# 3. NEVER commit `secrets.toml` — it's already in the repo's .gitignore.
#
# Get a Gemini key at https://aistudio.google.com/apikey

GEMINI_API_KEY = "PASTE_YOUR_NEW_KEY_HERE"

# ---------- Authentication ----------
# Keys are email addresses (lowercase), values are SHA-256 hex digests
# of the password. Generate a hash with:
#     python -c "import hashlib; print(hashlib.sha256(b'YOUR_PASSWORD').hexdigest())"
#
[auth]
# "user@example.com" = "sha256_hex_digest_of_password"
